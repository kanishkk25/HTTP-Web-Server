#ifndef __TMWP__
#define __TMWP__
#include<iostream>
#include<map>
#include<utility>
using namespace std;

/*
	Namespace : tmwp
	Purpose : contains all classes related to the TM Web Projector HTTP server library.
*/
namespace tmwp
{
/*
	Class : Request
	Purpose : Represent the HTTP request received from the client.
*/
class Request
{
private:

/*
	this map will store parsed request information in key-value format
    	example:
        URL: /register?name=Kanishk&city=Ujjain

    	Stored as:
        name -> kanishk
        city -> Ujjain

    This class allows handlers to access request data
    using simple key lookups.
*/
map<string,string> requestMap;
public:
Request();
~Request();
void set(string key,string value);
string get(string key);
};

/*
	Class : Response
	Purpose : This class allows programmer to write html as an response in their handler functions
*/
class Response
{
private:
int clientSocketDescriptor;
public:
Response();
~Response();
void setDescriptor(int clientSocketDescriptor);
void sendHeader();

// user can write his / her html as a response using this write() function
void write(string html);
void close();
};

/*
	Class : TMServer
	Purpose : Main HTTP Server class

	Responsibilites:
	- Listens on given port number
	- Accepts client connection
	- Maps URL routes to handler functions
	- Invoke the appropriate handler for each request
*/
class TMServer
{
private:
int portNumber;		// port number on which server will listen

/*
	Maps URL path to handler funtion
	Each URL is associated with a function that process the request.
*/
map<string,void (*)(Request &,Response &)> ptrMap;
public:
TMServer(int portNumber);		// initialize server with port number
~TMServer();

// starts the server and begins listening for client requests
void start();

/*
	Registers a handler functions for specific URL
	Exmaple:
		tmserver.onRequest("/home",handlerFunctions);
*/
void onRequest(const char *url,void (*ptrOnRequest)(Request &,Response &));
};
}
#endif