#ifndef __TMWP__
#define __TMWP__
#include<iostream>
#include<map>
#include<utility>
using namespace std;

/*
	Namespace : tmwp
	Purpose : contains all classes related to the TM Web Projector HTTP server library.
*/
namespace tmwp
{
/*
	Class : Request
	Purpose : Represents the HTTP request received from the client.
*/
class Request
{
private:

/*
	Stores parsed request parameters in key-value format
    	example:
        URL: /register?name=Kanishk&city=Ujjain

    	Stored as:
        name -> kanishk
        city -> Ujjain

    This class allows handlers to access request data
    using simple key lookups.
*/
map<string,string> requestMap;
public:
Request();
~Request();

/*
	Stores a value for the specified key 

	Example:
	key="name"
	value="kanishk"

	only 
*/
private:
void set(string key,string value);

//	Allow TMServer to access the private set() method while parsing requests.
friend class TMServer;

//	Returns the value associated with the specified key
public:
string get(string key);
};

/*
	Class : Response
	Purpose : Represents the HTTP response sent back to client.
*/
class Response
{
private:
int clientSocketDescriptor;
public:
Response();
~Response();
void setDescriptor(int clientSocketDescriptor);
void sendHeader();

// Writes HTML/contents as the response body
void write(string html);

// Closes the client connection after sending response.
void close();
};

/*
	Class : TMServer
	Purpose : Main HTTP Server class

	Responsibilites:
	- Listens on given port number
	- Accepts client connection
	- Maps URL routes to handler functions
	- Invoke the appropriate handler for each request
*/
class TMServer
{
private:
int portNumber;		// port number on which server will listen

/*
	Maps URL path to handler funtions
	Each URL is associated with a function that processes the request.
*/
map<string,void (*)(Request &,Response &)> ptrMap;
public:
TMServer(int portNumber);		// initialize server with port number
~TMServer();

// starts the server and begins listening for client requests
void start();

/*
	Registers a handler function for specific URL
	
	Example:
	tmserver.onRequest("/home",handlerFunction);
*/
void onRequest(const char *url,void (*ptrOnRequest)(Request &,Response &));
};
}
#endif